# API Key dari pembuatan akun Molty Royale (prefix mr_live_)
API_KEY=mr_live_xxxxxxxxxxxxxx

# Mode entry: free atau paid
ENTRY_MODE=free

# Untuk paid mode offchain (default)
PAYMENT_MODE=offchain

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Interval cek status (ms)
POLL_INTERVAL_MS=10000

# (Untuk paid onchain, tambahkan OWNER_EOA dan PRIVATE_KEY)
# OWNER_EOA=0x...
# PRIVATE_KEY=0x...